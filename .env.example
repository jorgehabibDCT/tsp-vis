# Copy to `.env.development.local` (gitignored) for local dev.
# On Vercel, set the same variable in Project → Environment Variables (Production).

# HTTPS base URL of the Render API: scheme + host only, no trailing slash, no path.
# Leave unset to use the built-in browser mock (no network request).
# VITE_API_URL=https://your-service.onrender.com
