# InfluxDB 2.x — when all four are set, "Number of Entities" uses Flux; otherwise fully mocked.
# INFLUX_HOST=https://xxx.influxdata.com
# INFLUX_TOKEN=
# INFLUX_ORG=
# INFLUX_BUCKET=

# Optional: in-memory cache for GET /api/dashboard/tsp-comparison (full JSON). Default 60000 ms. Set 0 to disable.
# DASHBOARD_CACHE_TTL_MS=60000

# Optional overrides:
# INFLUX_ENTITY_RANGE=-3d
# INFLUX_QUERY_TIMEOUT_MS=60000
# INFLUX_PROVIDERS_MEASUREMENT=providers
# Event/alarm expandable metric: `_field`s on `providers` (label=label_count). Default: label_type only.
# To also count localized descriptions (may double-count vs label_type): INFLUX_EVENT_LABEL_FIELDS=label_type,label_dscrptn_es
# TSP_PROVIDER_SLUGS={"tsp-fleethub":"teltonika","tsp-tracklink":"hunter","tsp-nexus":"pegasus-iot-cloud"}
